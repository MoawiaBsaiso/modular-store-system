+'use client'
+
+import { useEffect, useRef } from 'react'
+
+interface Props {
+  onComplete: () => void
+}
+
+// ═══════════════════════════════════════════════════════════
+// لتبديل بين الأنيميشنين — غيّر هاد السطر فقط:
+//   'typography'  →  حروف تنبثق + بوابة مصعد
+//   'fill'        →  نص يمتلئ + curtain للأعلى
+// ═══════════════════════════════════════════════════════════
+const ANIMATION_TYPE: 'typography' | 'fill' = 'typography'
+
+export function IntroLoader({ onComplete }: Props) {
+  const panelTopRef  = useRef<HTMLDivElement>(null)
+  const panelBotRef  = useRef<HTMLDivElement>(null)
+  const panelSingle  = useRef<HTMLDivElement>(null)
+  const lettersRef   = useRef<HTMLDivElement>(null)
+  const fillTextRef  = useRef<HTMLSpanElement>(null)
+  const progressRef  = useRef<HTMLDivElement>(null)
+  const taglineRef   = useRef<HTMLParagraphElement>(null)
+  const wrapperRef   = useRef<HTMLDivElement>(null)
+
+  useEffect(() => {
+    let ctx: any = null
+
+    async function run() {
+      const { gsap } = await import('gsap')
+
+      ctx = gsap.context(async () => {
+
+        // ─────────────────────────────────────────────
+        // OPTION A: Typography Morphing + بوابة مصعد
+        // ─────────────────────────────────────────────
+        if (ANIMATION_TYPE === 'typography') {
+          const letters = Array.from(
+            lettersRef.current?.querySelectorAll('.salis-letter') ?? []
+          )
+
+          gsap.set(letters,       { scaleY: 0, y: 40, opacity: 0, transformOrigin: 'bottom center' })
+          gsap.set(taglineRef.current, { opacity: 0, y: 8 })
+
+          const tl = gsap.timeline()
+
+          // ١ — حروف تنبثق بـ elastic liquid
+          tl.to(letters, {
+            scaleY: 1, y: 0, opacity: 1,
+            duration: 0.75,
+            ease: 'elastic.out(1, 0.45)',
+            stagger: 0.09,
+          })
+
+          // ٢ — الحروف تتباعد
+          tl.to(lettersRef.current, {
+            gap: '10px',
+            duration: 0.5,
+            ease: 'power3.out',
+          }, '-=0.25')
+
+          // ٣ — tagline
+          tl.to(taglineRef.current, {
+            opacity: 1, y: 0,
+            duration: 0.45,
+            ease: 'power3.out',
+          }, '-=0.2')
+
+          // ٤ — توقف
+          tl.to({}, { duration: 0.75 })
+
+          // ٥ — fade out حروف
+          tl.to([letters, taglineRef.current], {
+            opacity: 0, y: -14,
+            duration: 0.3,
+            ease: 'power2.in',
+          })
+
+          // ٦ — بوابة المصعد تنفتح
+          tl.to(panelTopRef.current, {
+            y: '-100%',
+            duration: 0.95,
+            ease: 'power4.inOut',
+          }, '-=0.05')
+
+          tl.to(panelBotRef.current, {
+            y: '100%',
+            duration: 0.95,
+            ease: 'power4.inOut',
+          }, '<')
+
+          // ٧ — إخفاء الـ wrapper نهائياً
+          tl.to(wrapperRef.current, {
+            pointerEvents: 'none',
+            duration: 0,
+            onComplete,
+          })
+        }
+
+        // ─────────────────────────────────────────────
+        // OPTION B: Text Fill + Curtain للأعلى
+        // ─────────────────────────────────────────────
+        if (ANIMATION_TYPE === 'fill') {
+          gsap.set(fillTextRef.current,  { width: '0%' })
+          gsap.set(progressRef.current,  { width: '0%' })
+          gsap.set(taglineRef.current,   { opacity: 0, y: 8 })
+
+          const tl = gsap.timeline()
+
+          // ١ — progress bar + نص يمتلئ
+          tl.to([fillTextRef.current, progressRef.current], {
+            width: '100%',
+            duration: 1.7,
+            ease: 'power2.inOut',
+          })
+
+          // ٢ — tagline
+          tl.to(taglineRef.current, {
+            opacity: 1, y: 0,
+            duration: 0.4,
+            ease: 'power2.out',
+          }, '-=0.6')
+
+          // ٣ — توقف
+          tl.to({}, { duration: 0.4 })
+
+          // ٤ — curtain للأعلى
+          tl.to(panelSingle.current, {
+            y: '-100%',
+            duration: 0.9,
+            ease: 'power4.inOut',
+          })
+
+          tl.to(wrapperRef.current, {
+            pointerEvents: 'none',
+            duration: 0,
+            onComplete,
+          })
+        }
+
+      }, wrapperRef)
+    }
+
+    run()
+    return () => ctx?.revert()
+  }, [onComplete])
+
+  return (
+    <div
+      ref={wrapperRef}
+      style={{
+        position: 'fixed',
+        inset: 0,
+        zIndex: 999,
+        pointerEvents: 'all',
+      }}
+    >
+      {/* ── OPTION A — بوابة مصعد (نصفين) ── */}
+      {ANIMATION_TYPE === 'typography' && (
+        <>
+          <div
+            ref={panelTopRef}
+            style={{
+              position: 'absolute',
+              top: 0, left: 0, right: 0,
+              height: '50%',
+              background: 'linear-gradient(135deg, #FF6B6B, #FF8E53)',
+              zIndex: 2,
+            }}
+          />
+          <div
+            ref={panelBotRef}
+            style={{
+              position: 'absolute',
+              bottom: 0, left: 0, right: 0,
+              height: '50%',
+              background: 'linear-gradient(160deg, #FF8E53, #FF6B6B)',
+              zIndex: 2,
+            }}
+          />
+
+          {/* الحروف */}
+          <div
+            ref={lettersRef}
+            style={{
+              position: 'absolute',
+              inset: 0,
+              display: 'flex',
+              alignItems: 'center',
+              justifyContent: 'center',
+              gap: '2px',
+              zIndex: 3,
+            }}
+          >
+            {'Salis'.split('').map((char, i) => (
+              <span
+                key={i}
+                className="salis-letter"
+                style={{
+                  fontSize: 'clamp(64px, 12vw, 96px)',
+                  fontWeight: 900,
+                  color: '#fff',
+                  letterSpacing: '-2px',
+                  lineHeight: 1,
+                  display: 'inline-block',
+                }}
+              >
+                {char}
+              </span>
+            ))}
+          </div>
+
+          {/* tagline */}
+          <p
+            ref={taglineRef}
+            style={{
+              position: 'absolute',
+              bottom: 'calc(50% - 60px)',
+              left: 0, right: 0,
+              textAlign: 'center',
+              zIndex: 3,
+              fontSize: '12px',
+              fontWeight: 600,
+              letterSpacing: '0.18em',
+              color: 'rgba(255,255,255,0.65)',
+              textTransform: 'uppercase',
+            }}
+          >
+            تسوق ببساطة
+          </p>
+        </>
+      )}
+
+      {/* ── OPTION B — curtain للأعلى ── */}
+      {ANIMATION_TYPE === 'fill' && (
+        <div
+          ref={panelSingle}
+          style={{
+            position: 'absolute',
+            inset: 0,
+            background: 'linear-gradient(135deg, #FF6B6B, #FF8E53)',
+            zIndex: 2,
+            display: 'flex',
+            flexDirection: 'column',
+            alignItems: 'center',
+            justifyContent: 'center',
+            gap: '20px',
+          }}
+        >
+          {/* النص مع fill */}
+          <div style={{ position: 'relative' }}>
+            {/* النص الشبح */}
+            <span style={{
+              fontSize: 'clamp(64px, 12vw, 96px)',
+              fontWeight: 900,
+              color: 'rgba(255,255,255,0.2)',
+              letterSpacing: '-3px',
+              lineHeight: 1,
+              userSelect: 'none',
+            }}>
+              Salis
+            </span>
+            {/* النص المملوء */}
+            <span
+              ref={fillTextRef}
+              style={{
+                position: 'absolute',
+                top: 0, left: 0,
+                fontSize: 'clamp(64px, 12vw, 96px)',
+                fontWeight: 900,
+                color: '#fff',
+                letterSpacing: '-3px',
+                lineHeight: 1,
+                overflow: 'hidden',
+                whiteSpace: 'nowrap',
+                width: '0%',
+              }}
+            >
+              Salis
+            </span>
+          </div>
+
+          {/* Progress bar */}
+          <div style={{
+            width: '100px',
+            height: '2px',
+            background: 'rgba(255,255,255,0.2)',
+            borderRadius: '99px',
+            overflow: 'hidden',
+          }}>
+            <div
+              ref={progressRef}
+              style={{
+                height: '100%',
+                background: '#fff',
+                width: '0%',
+                borderRadius: '99px',
+              }}
+            />
+          </div>
+
+          {/* tagline */}
+          <p
+            ref={taglineRef}
+            style={{
+              fontSize: '12px',
+              fontWeight: 600,
+              letterSpacing: '0.18em',
+              color: 'rgba(255,255,255,0.65)',
+              textTransform: 'uppercase',
+            }}
+          >
+            تسوق ببساطة
+          </p>
+        </div>
+      )}
+    </div>
+  )
+}
